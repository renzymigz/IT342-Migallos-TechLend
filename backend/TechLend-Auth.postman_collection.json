{
	"info": {
		"_postman_id": "techlend-auth-collection",
		"name": "TechLend - Local Auth",
		"description": "Local User Registration and Authentication endpoints for TechLend API v1",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8080/api/v1",
			"type": "string"
		},
		{
			"key": "accessToken",
			"value": "",
			"type": "string"
		},
		{
			"key": "refreshToken",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Register",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"if (pm.response.code === 201) {",
							"    var jsonData = pm.response.json();",
							"    if (jsonData.success && jsonData.data && jsonData.data.tokens) {",
							"        pm.collectionVariables.set('accessToken', jsonData.data.tokens.accessToken);",
							"        pm.collectionVariables.set('refreshToken', jsonData.data.tokens.refreshToken);",
							"    }",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"schoolId\": \"20-1234-567\",\n    \"email\": \"juan.delacruz@cit.edu\",\n    \"password\": \"SecureP@ss1\",\n    \"firstName\": \"Juan\",\n    \"lastName\": \"Dela Cruz\",\n    \"contactNumber\": \"+639171234567\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/auth/register",
					"host": ["{{baseUrl}}"],
					"path": ["auth", "register"]
				},
				"description": "Register a new local user. Returns user profile + JWT tokens."
			},
			"response": []
		},
		{
			"name": "Login (by email)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"if (pm.response.code === 200) {",
							"    var jsonData = pm.response.json();",
							"    if (jsonData.success && jsonData.data && jsonData.data.tokens) {",
							"        pm.collectionVariables.set('accessToken', jsonData.data.tokens.accessToken);",
							"        pm.collectionVariables.set('refreshToken', jsonData.data.tokens.refreshToken);",
							"    }",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"identifier\": \"juan.delacruz@cit.edu\",\n    \"password\": \"SecureP@ss1\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/auth/login",
					"host": ["{{baseUrl}}"],
					"path": ["auth", "login"]
				},
				"description": "Login with email or school_id as identifier."
			},
			"response": []
		},
		{
			"name": "Login (by school_id)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"if (pm.response.code === 200) {",
							"    var jsonData = pm.response.json();",
							"    if (jsonData.success && jsonData.data && jsonData.data.tokens) {",
							"        pm.collectionVariables.set('accessToken', jsonData.data.tokens.accessToken);",
							"        pm.collectionVariables.set('refreshToken', jsonData.data.tokens.refreshToken);",
							"    }",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"identifier\": \"20-1234-567\",\n    \"password\": \"SecureP@ss1\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/auth/login",
					"host": ["{{baseUrl}}"],
					"path": ["auth", "login"]
				},
				"description": "Login using school_id as identifier."
			},
			"response": []
		},
		{
			"name": "Logout",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"if (pm.response.code === 200) {",
							"    pm.collectionVariables.set('accessToken', '');",
							"    pm.collectionVariables.set('refreshToken', '');",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{accessToken}}"
					}
				],
				"url": {
					"raw": "{{baseUrl}}/auth/logout",
					"host": ["{{baseUrl}}"],
					"path": ["auth", "logout"]
				},
				"description": "Invalidates the current access token server-side. Clears stored tokens on success."
			},
			"response": []
		},
		{
			"name": "Get Current User (me)",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{accessToken}}"
					}
				],
				"url": {
					"raw": "{{baseUrl}}/users/me",
					"host": ["{{baseUrl}}"],
					"path": ["users", "me"]
				},
				"description": "Returns the authenticated user's profile. Requires a valid access token."
			},
			"response": []
		}
	]
}
